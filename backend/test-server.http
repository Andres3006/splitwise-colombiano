@baseUrl = http://localhost:3000
@token = REEMPLAZA_CON_TU_TOKEN
@userId1 = REEMPLAZA_CON_UUID_1
@userId2 = REEMPLAZA_CON_UUID_2
@userId3 = REEMPLAZA_CON_UUID_3
@groupId = REEMPLAZA_CON_GROUP_ID
@invitationId = REEMPLAZA_CON_INVITATION_ID

### Salud del servidor
GET {{baseUrl}}/

### Conexion con base de datos
GET {{baseUrl}}/db-test

### Endpoint de prueba
GET {{baseUrl}}/api/test

### Registro
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Usuario Demo",
  "email": "demo@test.com",
  "password": "123456",
  "birth_date": "2000-01-01"
}

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "demo@test.com",
  "password": "123456"
}

### Ruta privada
GET {{baseUrl}}/private
Authorization: Bearer {{token}}

### Crear grupo
POST {{baseUrl}}/api/groups
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Viaje Cartagena",
  "members": [
    "{{userId2}}"
  ]
}

### Ver mis grupos
GET {{baseUrl}}/api/groups/me
Authorization: Bearer {{token}}

### Ver detalle de grupo
GET {{baseUrl}}/api/groups/{{groupId}}
Authorization: Bearer {{token}}

### Agregar miembro al grupo
POST {{baseUrl}}/api/groups/{{groupId}}/members
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "user_id": "{{userId3}}"
}

### Invitar usuario al grupo
POST {{baseUrl}}/api/groups/{{groupId}}/invitations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "invited_user_id": "{{userId3}}"
}

### Ver mis invitaciones
GET {{baseUrl}}/api/groups/invitations/me
Authorization: Bearer {{token}}

### Responder invitacion
PATCH {{baseUrl}}/api/groups/invitations/{{invitationId}}/respond
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "action": "accept"
}

### Crear gasto con division equitativa
POST {{baseUrl}}/api/expenses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Cena",
  "amount": 90000,
  "paid_by": "{{userId1}}",
  "split_type": "equal",
  "participants": [
    "{{userId1}}",
    "{{userId2}}",
    "{{userId3}}"
  ],
  "currency": "COP"
}

### Crear gasto con division personalizada
POST {{baseUrl}}/api/expenses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Mercado",
  "amount": 100000,
  "paid_by": "{{userId1}}",
  "split_type": "custom",
  "participants": [
    { "user_id": "{{userId1}}", "share_amount": 20000 },
    { "user_id": "{{userId2}}", "share_amount": 30000 },
    { "user_id": "{{userId3}}", "share_amount": 50000 }
  ],
  "currency": "COP"
}

### Ver mis balances
GET {{baseUrl}}/api/balances/me
Authorization: Bearer {{token}}

### Optimizar pagos
GET {{baseUrl}}/api/balances/optimize
Authorization: Bearer {{token}}

### Optimizar pagos por grupo
GET {{baseUrl}}/api/balances/optimize?group_id={{groupId}}
Authorization: Bearer {{token}}

### Dashboard
GET {{baseUrl}}/api/dashboard/me
Authorization: Bearer {{token}}

### Registrar pago
POST {{baseUrl}}/api/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "to_user": "{{userId1}}",
  "amount": 20000
}
